PORT=8080
GCS_BUCKET_NAME=your-cloud-storage-bucket-name  # comma-separated for multiple buckets, e.g. bucket-a,bucket-b
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GEMINI_API_KEY=your-gemini-api-key
SERVICE_ACCOUNT_FILE=  # optional: path to service account key JSON for GCS auth (uses ADC if unset)
